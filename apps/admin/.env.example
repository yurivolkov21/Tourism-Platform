# apps/admin environment — copy to .env and fill. NEVER commit .env (gitignored).
# Only NEXT_PUBLIC_* values are exposed to the browser; the anon key is client-safe.

# Supabase (same project as the API). Admin sign-in uses these.
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Tourism API origin (routes already include /api/v1). API runs on :3000 in dev.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1

# NOTE (one-time API config to actually sign in as admin):
#  - your email must be in apps/api .env ADMIN_EMAILS
#  - add this admin origin to apps/api .env CORS_ORIGINS (admin dev runs on :3002)
