{
  "name": "@tourism/mobile",
  "version": "0.0.1",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "eas-build-post-install": "cd ../../ && node tools/scripts/eas-build-post-install.mjs . apps/mobile"
  },
  "nx": {
    "tags": [
      "scope:mobile",
      "type:app"
    ],
    "targets": {
      "build": {
        "executor": "nx:run-commands",
        "options": {
          "command": "pnpm exec expo export",
          "cwd": "apps/mobile"
        },
        "outputs": [
          "{projectRoot}/dist"
        ],
        "cache": true,
        "dependsOn": [
          "^build"
        ],
        "metadata": {
          "description": "Production Metro bundle check (expo export). Overrides the inferred `eas build` target - this app ships via Expo Go, no EAS account/cli on dev machines."
        }
      }
    }
  },
  "dependencies": {
    "@expo-google-fonts/fraunces": "^0.4.1",
    "@expo-google-fonts/geist": "^0.4.2",
    "@expo/metro-config": "~54.0.9",
    "@expo/vector-icons": "^15.1.1",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.3.7",
    "@supabase/supabase-js": "^2.108.2",
    "@tanstack/react-query": "^5.101.2",
    "@testing-library/react-native": "^13.2.2",
    "@tourism/core": "workspace:*",
    "@tourism/i18n": "workspace:*",
    "@tourism/mobile-ui": "workspace:*",
    "@tourism/tokens": "workspace:*",
    "expo": "~54.0.0",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.24",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.11",
    "jest-expo": "~54.0.17",
    "metro-config": "~0.84.0",
    "metro-resolver": "~0.84.0",
    "react": "^19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.7",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-svg-transformer": "~1.5.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "babel-preset-expo": "~54.0.11"
  }
}
