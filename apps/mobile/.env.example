# apps/mobile environment — copy to .env and fill. NEVER commit .env (gitignored).
# ALL FOUR vars are REQUIRED with no defaults — src/lib/env.ts throws at import
# time if any is missing. Nx auto-loads this app's .env (NX_LOAD_DOT_ENV_FILES),
# so run tests through nx; the Expo dev loop is `pnpm exec expo start` from
# apps/mobile.

# Tourism API ORIGIN — no /api/v1 suffix (the @tourism/core client adds it).
# On a physical device "localhost" is the PHONE, not your PC — use your PC's
# LAN IP (http://192.168.x.x:3000) or the live Render API.
EXPO_PUBLIC_API_BASE_URL=https://tourism-api-pqwr.onrender.com

# Supabase (same project as web/admin/API). Project Settings -> API.
EXPO_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# The deployed web app origin — Account-tab legal links + password reset open it.
EXPO_PUBLIC_WEB_URL=https://<your-web-deployment>.vercel.app
