# apps/mobile — copy to .env (gitignored). EXPO_PUBLIC_* is embedded at build time.
#
# Production-first (default): same API + DB as web on Vercel.
# Do NOT add /api/v1 — the client appends it.
EXPO_PUBLIC_API_BASE_URL=https://tourism-api-pqwr.onrender.com
#
# Local API only when debugging backend changes (run `pnpm nx serve @tourism/api`):
#   iOS simulator:     http://localhost:3000
#   Android emulator:  http://10.0.2.2:3000
#   Physical device:   http://<your-LAN-IP>:3000
