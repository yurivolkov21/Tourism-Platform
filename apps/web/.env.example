# apps/web environment — copy to .env and fill. NEVER commit .env (gitignored).
# Only NEXT_PUBLIC_* values are exposed to the browser.

# Tourism API ORIGIN — do NOT add /api/v1 (the @tourism/core client adds it).
#   Local API:   http://localhost:3000   (run `pnpm nx serve @tourism/api`)
#   Live (Render): https://tourism-api-pqwr.onrender.com
# Defaults to http://localhost:3000 when unset (see src/lib/api/client.ts).
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# DEV PORT MAP (no clashes — the API owns :3000):
#   API (NestJS) -> http://localhost:3000   (pnpm nx serve @tourism/api)
#   Web          -> http://localhost:3001   (pnpm nx dev @tourism/web)
#   Admin        -> http://localhost:3002   (pnpm nx dev @tourism/admin)
#
# NOTE: with no API reachable, data-fed sections (featured tours, "Explore by
# destination", etc.) render EMPTY by design — the page hides a section rather
# than show it broken. That's expected, not a bug. Point this at the live Render
# API above to see real data without running the backend locally.
