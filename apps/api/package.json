{
  "name": "@tourism/api",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "targets": {
      "seed": {
        "executor": "nx:run-commands",
        "options": {
          "command": "pnpm exec ts-node --transpile-only prisma/seed.ts",
          "cwd": "apps/api"
        }
      },
      "reset": {
        "executor": "nx:run-commands",
        "options": {
          "command": "pnpm exec ts-node --transpile-only prisma/reset.ts",
          "cwd": "apps/api"
        }
      },
      "refresh-posts": {
        "executor": "nx:run-commands",
        "options": {
          "command": "pnpm exec ts-node --transpile-only prisma/refresh-post-content.ts",
          "cwd": "apps/api"
        }
      },
      "e2e": {
        "executor": "nx:run-commands",
        "options": {
          "command": "pnpm exec jest --config jest.config.e2e.cts --runInBand",
          "cwd": "apps/api"
        }
      },
      "build": {
        "executor": "nx:run-commands",
        "options": {
          "command": "webpack-cli build",
          "args": [
            "--node-env=production"
          ],
          "cwd": "apps/api"
        },
        "configurations": {
          "development": {
            "args": [
              "--node-env=development"
            ]
          }
        }
      },
      "prune-lockfile": {
        "dependsOn": [
          "build"
        ],
        "cache": true,
        "executor": "@nx/js:prune-lockfile",
        "outputs": [
          "{workspaceRoot}/apps/api/dist/package.json",
          "{workspaceRoot}/apps/api/dist/pnpm-lock.yaml"
        ],
        "options": {
          "buildTarget": "build"
        }
      },
      "copy-workspace-modules": {
        "dependsOn": [
          "build"
        ],
        "cache": true,
        "outputs": [
          "{workspaceRoot}/apps/api/dist/workspace_modules"
        ],
        "executor": "@nx/js:copy-workspace-modules",
        "options": {
          "buildTarget": "build"
        }
      },
      "prune": {
        "dependsOn": [
          "prune-lockfile",
          "copy-workspace-modules"
        ],
        "executor": "nx:noop"
      },
      "serve": {
        "continuous": true,
        "executor": "@nx/js:node",
        "defaultConfiguration": "development",
        "dependsOn": [
          "build"
        ],
        "options": {
          "buildTarget": "@tourism/api:build",
          "runBuildTargetDependencies": false
        },
        "configurations": {
          "development": {
            "buildTarget": "@tourism/api:build:development"
          },
          "production": {
            "buildTarget": "@tourism/api:build:production"
          }
        }
      },
      "test": {
        "options": {
          "passWithNoTests": true
        }
      }
    },
    "tags": [
      "scope:api",
      "type:app"
    ]
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/throttler": "^6.5.0",
    "@paypal/paypal-server-sdk": "^2.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/node": "^10.57.0",
    "@tourism/core": "workspace:*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cloudinary": "^2.10.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "joi": "^18.2.1",
    "jose": "^6.2.3",
    "pg": "^8.21.0",
    "pg-boss": "^12.19.1",
    "reflect-metadata": "^0.1.13",
    "resend": "^6.14.0",
    "rxjs": "^7.8.0",
    "stripe": "^22.2.1",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.0.0",
    "@types/express": "^5.0.6",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2"
  }
}
