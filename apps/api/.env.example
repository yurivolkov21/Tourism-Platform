# apps/api environment — copy to .env and fill. NEVER commit .env (gitignored).
# Schema/source of truth: apps/api/src/config/env.validation.ts (Joi, fail-fast).

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3001

# ── Database (Supabase Postgres) ─────────────────────────────────────────────
# DATABASE_URL = Supavisor transaction pooler (port 6543) — used at runtime.
# DIRECT_URL   = direct connection (port 5432) — used by prisma migrate.
DATABASE_URL=postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:6543/postgres
DIRECT_URL=postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:5432/postgres

# ── Supabase Auth ────────────────────────────────────────────────────────────
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWKS_URL=https://<ref>.supabase.co/auth/v1/.well-known/jwks.json
# Optional legacy HS256 secret (new projects use asymmetric keys — leave blank):
SUPABASE_JWT_SECRET=
# Comma-separated admin allowlist:
ADMIN_EMAILS=

# ── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=tourism

# ── Stripe (international) ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_DEFAULT_CURRENCY=usd
FRONTEND_URL=http://localhost:3001

# ── PayPal (international — ADR-0006 amended; replaced MoMo) ──────────────────
# REQUIRED non-empty since API-W2 (fail-fast at boot — no silently broken
# gateway). Sandbox creds: developer.paypal.com → app → client id/secret;
# webhook id from the app's webhook config. PAYPAL_MODE = sandbox | live.
PAYPAL_CLIENT_ID=sandbox-client-id
PAYPAL_CLIENT_SECRET=sandbox-secret
PAYPAL_MODE=sandbox
PAYPAL_WEBHOOK_ID=sandbox-webhook-id

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Tourism <noreply@example.com>
# Optional: support inbox that replies land in (blank = no Reply-To header)
RESEND_REPLY_TO_EMAIL=

# ── Observability (Sentry — ADR-0008) ────────────────────────────────────────
SENTRY_DSN=

# ── AI Concierge Chat (Anthropic via Vercel AI SDK) ──────────────────────────
# OPTIONAL — with no key the chat endpoint answers 503 CHAT_UNAVAILABLE and the
# web chat panel shows its "unavailable" state; everything else runs normally.
# Key: console.anthropic.com → API keys. Model is swappable (AI SDK).
ANTHROPIC_API_KEY=
CHAT_MODEL=claude-haiku-4-5

# ── Throttler ────────────────────────────────────────────────────────────────
# Default window/limit for the PUBLIC endpoints (enquiry + newsletter forms).
# The enquiry POST additionally tightens itself to 5/min via @Throttle.
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=100
