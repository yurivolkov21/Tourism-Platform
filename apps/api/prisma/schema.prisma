// Tourism API — Prisma schema (rebuilt clean, English-only).
// Decisions: ADR-0002 (M:N), 0003 (Enquiry), 0005 (EN-only), 0006 (multi-gateway),
// 0008 (integrity). Hardening that Prisma can't express (citext, CHECK, RLS)
// lives in `prisma/hardening.sql`, folded into the migration when the DB lands
// (D-P1.6). See docs/01-architecture/data-model.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Runtime URL comes from the PrismaPg adapter (DATABASE_URL); migrations read
  // DIRECT_URL via prisma.config.ts. No url here (Prisma 7).
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum UserRole {
  CUSTOMER
  ADMIN
}

enum DepartureStatus {
  OPEN
  CLOSED
  CANCELLED
}

enum BookingStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
}

/// Payment rail for a booking (ADR-0006, amended). Stripe = cards/wallets,
/// PayPal = international travellers (replaced MoMo — audience is inbound foreign).
enum PaymentProvider {
  STRIPE
  PAYPAL
}

/// Lead lifecycle for "Inquire Now" (ADR-0003, D-P1.4 — CRM).
enum EnquiryStatus {
  NEW
  CONTACTED
  QUOTED
  WON
  LOST
}

/// Support lifecycle for a PAID-booking cancellation request (2026-07-04).
enum CancellationRequestStatus {
  REQUESTED
  REFUNDED
  DENIED
}

enum MediaType {
  IMAGE
  VIDEO
}

enum MediaOwnerType {
  TOUR
  DESTINATION
  USER
  POST
  SITE
}

/// Slot a media asset occupies within its owner. Closed enum (security-first).
enum MediaRole {
  hero
  gallery
  avatar
  body
}

/// Kind of a tour policy (D-P1.1 — TourPolicy is its own model).
enum PolicyKind {
  CANCELLATION
  BOOKING
  GENERAL
}

/// Traveller types a tour suits (P1.7e merchandising — donor/Lily's "theme").
enum TravellerType {
  FAMILY
  COUPLE
  FRIENDS
  SOLO
  BUSINESS
}

// VERIFIED = earned from a real booking; CURATED = admin-authored testimonial.
enum ReviewSource {
  VERIFIED
  CURATED
}

/// Merchandising badge on a tour card (P1.7e — donor/Lily's labels).
enum TourBadge {
  BEST_VALUE
  LIMITED_OFFER
  EXCLUSIVE
  NEW
  POPULAR
}

/// Transactional email kind for the outbox (ADR-0007, P1.x).
enum EmailType {
  BOOKING_CONFIRMATION
  BOOKING_REFUNDED
  REVIEW_APPROVED
  ENQUIRY_RECEIVED
  CANCELLATION_REQUESTED
  CANCELLATION_DENIED
}

/// Outbox row lifecycle (ADR-0007). PENDING → SENT, or → FAILED after retries.
enum OutboxStatus {
  PENDING
  SENT
  FAILED
}

/// Editorial blog post lifecycle (P-Content). DRAFT → PUBLISHED.
enum PostStatus {
  DRAFT
  PUBLISHED
}

// ─────────────────────────────────────────────────────────────────────────────
// User — local mirror of Supabase auth.users
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id         String   @id @default(uuid()) @db.Uuid
  supabaseId String   @unique @map("supabase_id") @db.Uuid
  // Case-insensitive unique email via Postgres citext (ADR-0008). The citext
  // extension is created in the hardening migration (CREATE EXTENSION) ahead of
  // the column ALTER.
  email      String   @unique @db.Citext
  fullName   String?  @map("full_name") @db.VarChar(120)
  phone      String?  @db.VarChar(20)
  // EN-only (ADR-0005) — kept as a default-"en" door-opener, no enum.
  locale     String   @default("en") @db.VarChar(10)
  role       UserRole @default(CUSTOMER)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  bookings         Booking[] @relation("BookingCustomer")
  refundedBookings Booking[] @relation("BookingRefundedBy")
  reviews          Review[]
  wishlist         Wishlist[]
  posts            Post[]
  cancellationRequests  CancellationRequest[] @relation("CancellationRequester")
  cancellationDecisions CancellationRequest[] @relation("CancellationDecider")
  enquiryNotes          EnquiryNote[]

  @@index([role])
  @@map("users")
}

// ─────────────────────────────────────────────────────────────────────────────
// TourCategory — lookup table (D-P1.5; replaces the donor enum, resolves R8)
// ─────────────────────────────────────────────────────────────────────────────

model TourCategory {
  id          String   @id @default(uuid()) @db.Uuid
  slug        String   @unique @db.VarChar(60)
  name        String   @db.VarChar(120)
  description String?  @db.VarChar(500)
  order       Int      @default(0)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tours Tour[]

  @@index([isActive, order])
  @@map("tour_categories")
}

// ─────────────────────────────────────────────────────────────────────────────
// Destination
// ─────────────────────────────────────────────────────────────────────────────

model Destination {
  id          String   @id @default(uuid()) @db.Uuid
  slug        String   @unique @db.VarChar(80)
  name        String   @db.VarChar(120)
  country     String   @default("Vietnam") @db.VarChar(60)
  region      String?  @db.VarChar(80)
  description String?  @db.VarChar(2000)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tours TourDestination[]

  @@index([isActive])
  @@map("destinations")
}

// ─────────────────────────────────────────────────────────────────────────────
// Tour
// ─────────────────────────────────────────────────────────────────────────────

model Tour {
  id              String   @id @default(uuid()) @db.Uuid
  slug            String   @unique @db.VarChar(120)
  title           String   @db.VarChar(200)
  summary         String?  @db.VarChar(500)
  categoryId      String   @map("category_id") @db.Uuid
  durationDays    Int      @map("duration_days")
  maxGroupSize    Int      @default(20) @map("max_group_size")
  basePrice       Decimal  @map("base_price") @db.Decimal(12, 2)
  // Price anchoring (D-P1.3) — optional "compare at" / strike-through price.
  compareAtPrice  Decimal? @map("compare_at_price") @db.Decimal(12, 2)
  currency        String   @default("USD") @db.VarChar(3)
  difficulty      String?  @db.VarChar(30)
  isPublished     Boolean  @default(false) @map("is_published")
  isFeatured      Boolean  @default(false) @map("is_featured")
  // Merchandising (P1.7e) — who the tour suits + card badges (donor/Lily's).
  suitableFor     TravellerType[] @default([]) @map("suitable_for")
  badges          TourBadge[]     @default([])
  // EN-only arrays (ADR-0005) → Postgres text[].
  included        String[] @default([])
  excluded        String[] @default([])
  highlights      String[] @default([])
  meetingPoint    String?  @map("meeting_point") @db.VarChar(300)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  category     TourCategory       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  destinations TourDestination[]
  itinerary    TourItineraryDay[]
  departures   TourDeparture[]
  faqs         TourFaq[]
  policies     TourPolicy[]
  bookings     Booking[]
  reviews      Review[]
  wishlist     Wishlist[]
  enquiries    Enquiry[]
  posts        PostTour[]

  @@index([isPublished, categoryId])
  @@index([isFeatured, isPublished])
  @@map("tours")
}

// ─────────────────────────────────────────────────────────────────────────────
// TourDestination — M:N join (ADR-0002), with primary-destination flag
// ─────────────────────────────────────────────────────────────────────────────

model TourDestination {
  tourId        String  @map("tour_id") @db.Uuid
  destinationId String  @map("destination_id") @db.Uuid
  isPrimary     Boolean @default(false) @map("is_primary")

  tour        Tour        @relation(fields: [tourId], references: [id], onDelete: Cascade)
  destination Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  @@id([tourId, destinationId])
  @@index([tourId])
  @@index([destinationId, isPrimary])
  @@map("tour_destinations")
}

// ─────────────────────────────────────────────────────────────────────────────
// TourItineraryDay — one row per day
// ─────────────────────────────────────────────────────────────────────────────

model TourItineraryDay {
  id          String  @id @default(uuid()) @db.Uuid
  tourId      String  @map("tour_id") @db.Uuid
  dayNumber   Int     @map("day_number")
  title       String  @db.VarChar(200)
  description String? @db.VarChar(2000)

  tour Tour @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@unique([tourId, dayNumber])
  @@map("tour_itinerary_days")
}

// ─────────────────────────────────────────────────────────────────────────────
// TourDeparture — concrete dates
// ─────────────────────────────────────────────────────────────────────────────

model TourDeparture {
  id             String          @id @default(uuid()) @db.Uuid
  tourId         String          @map("tour_id") @db.Uuid
  startDate      DateTime        @map("start_date") @db.Date
  endDate        DateTime        @map("end_date") @db.Date
  priceOverride  Decimal?        @map("price_override") @db.Decimal(12, 2)
  // Departure-level price anchor (D-P1.3).
  compareAtPrice Decimal?        @map("compare_at_price") @db.Decimal(12, 2)
  seatsTotal     Int             @map("seats_total")
  seatsBooked    Int             @default(0) @map("seats_booked")
  status         DepartureStatus @default(OPEN)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  tour     Tour      @relation(fields: [tourId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([tourId, startDate])
  @@index([status])
  @@map("tour_departures")
}

// ─────────────────────────────────────────────────────────────────────────────
// TourFaq
// ─────────────────────────────────────────────────────────────────────────────

model TourFaq {
  id       String @id @default(uuid()) @db.Uuid
  tourId   String @map("tour_id") @db.Uuid
  question String @db.VarChar(300)
  answer   String @db.VarChar(2000)
  order    Int    @default(0)

  tour Tour @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@index([tourId, order])
  @@map("tour_faqs")
}

// ─────────────────────────────────────────────────────────────────────────────
// TourPolicy — structured policy (D-P1.1)
// ─────────────────────────────────────────────────────────────────────────────

model TourPolicy {
  id     String     @id @default(uuid()) @db.Uuid
  tourId String     @map("tour_id") @db.Uuid
  kind   PolicyKind
  title  String     @db.VarChar(200)
  body   String     @db.VarChar(4000)
  order  Int        @default(0)

  tour Tour @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@index([tourId, kind])
  @@map("tour_policies")
}

// ─────────────────────────────────────────────────────────────────────────────
// Booking — multi-gateway (ADR-0006) + integrity hardening (ADR-0008)
// ─────────────────────────────────────────────────────────────────────────────

model Booking {
  id                 String          @id @default(uuid()) @db.Uuid
  code               String          @unique @db.VarChar(20)
  userId             String          @map("user_id") @db.Uuid
  tourId             String          @map("tour_id") @db.Uuid
  departureId        String          @map("departure_id") @db.Uuid
  numAdults          Int             @map("num_adults")
  numChildren        Int             @default(0) @map("num_children")
  totalAmount        Decimal         @map("total_amount") @db.Decimal(12, 2)
  currency           String          @default("USD") @db.VarChar(3)
  status             BookingStatus   @default(PENDING)
  contactName        String          @map("contact_name") @db.VarChar(120)
  contactEmail       String          @map("contact_email") @db.VarChar(200)
  contactPhone       String?         @map("contact_phone") @db.VarChar(30)
  specialRequests    String?         @map("special_requests") @db.VarChar(1000)
  // Provider-neutral payment refs (ADR-0006). `providerSessionId` is the
  // Checkout session / MoMo order id; `providerPaymentId` the captured payment.
  paymentProvider    PaymentProvider @map("payment_provider")
  providerSessionId  String?         @unique @map("provider_session_id") @db.VarChar(255)
  providerPaymentId  String?         @map("provider_payment_id") @db.VarChar(255)
  // Admin refund audit. `refundedById` is now a real FK (SetNull) — ADR-0008.
  refundReason       String?         @map("refund_reason") @db.VarChar(500)
  refundedById       String?         @map("refunded_by") @db.Uuid
  refundedAmount     Decimal?        @map("refunded_amount") @db.Decimal(12, 2)
  refundedAt         DateTime?       @map("refunded_at")
  paidAt             DateTime?       @map("paid_at")
  cancelledAt        DateTime?       @map("cancelled_at")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")

  user       User          @relation("BookingCustomer", fields: [userId], references: [id], onDelete: Restrict)
  refundedBy User?         @relation("BookingRefundedBy", fields: [refundedById], references: [id], onDelete: SetNull)
  tour       Tour          @relation(fields: [tourId], references: [id], onDelete: Restrict)
  departure  TourDeparture @relation(fields: [departureId], references: [id], onDelete: Restrict)
  reviews    Review[]
  cancellationRequest CancellationRequest?

  @@index([userId, status])
  @@index([departureId])
  @@index([status, createdAt])
  @@index([tourId])
  @@map("bookings")
}

// ─────────────────────────────────────────────────────────────────────────────
// CancellationRequest — a PAID customer's request to cancel/refund a booking
// (2026-07-04). One live row per booking (unique bookingId); a DENIED row is
// reused on re-request. Admin acts from the queue: refund resolves it to
// REFUNDED (see BookingsService.refundByAdmin), deny → DENIED.
// ─────────────────────────────────────────────────────────────────────────────

model CancellationRequest {
  id           String                    @id @default(uuid()) @db.Uuid
  bookingId    String                    @unique @map("booking_id") @db.Uuid
  userId       String                    @map("user_id") @db.Uuid
  reason       String                    @db.VarChar(1000)
  status       CancellationRequestStatus @default(REQUESTED)
  decisionNote String?                   @map("decision_note") @db.VarChar(500)
  decidedById  String?                   @map("decided_by") @db.Uuid
  decidedAt    DateTime?                 @map("decided_at")
  createdAt    DateTime                  @default(now()) @map("created_at")
  updatedAt    DateTime                  @updatedAt @map("updated_at")

  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Restrict)
  user      User    @relation("CancellationRequester", fields: [userId], references: [id], onDelete: Restrict)
  decidedBy User?   @relation("CancellationDecider", fields: [decidedById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@map("cancellation_requests")
}

// ─────────────────────────────────────────────────────────────────────────────
// Review — one per booking (rating 1..5 enforced by CHECK in hardening.sql)
// ─────────────────────────────────────────────────────────────────────────────

model Review {
  id         String   @id @default(uuid()) @db.Uuid
  // FKs are nullable so a CURATED testimonial can exist without a real booking/user/tour.
  // VERIFIED reviews keep all three set (unchanged behaviour).
  tourId     String?  @map("tour_id") @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  bookingId  String?  @unique @map("booking_id") @db.Uuid
  rating     Int
  title      String?  @db.VarChar(120)
  body       String   @db.VarChar(2000)
  // Snapshot display name (verified: copied from user.fullName at create; curated: admin-entered).
  authorName     String       @map("author_name") @db.VarChar(120)
  // Free-text "City, Country" — curated only (the customer review form doesn't capture it).
  authorLocation String?      @map("author_location") @db.VarChar(120)
  source         ReviewSource @default(VERIFIED)
  isFeatured     Boolean      @default(false) @map("is_featured")
  // Free-text trip name for curated rows with no tourId (else the tour title is used).
  tripLabel      String?      @map("trip_label") @db.VarChar(160)
  isApproved Boolean  @default(false) @map("is_approved")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tour    Tour?    @relation(fields: [tourId], references: [id], onDelete: Cascade)
  user    User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([tourId, isApproved])
  @@index([userId])
  @@index([isApproved, isFeatured])
  @@map("reviews")
}

// ─────────────────────────────────────────────────────────────────────────────
// Wishlist — composite PK (user, tour)
// ─────────────────────────────────────────────────────────────────────────────

model Wishlist {
  userId    String   @map("user_id") @db.Uuid
  tourId    String   @map("tour_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  tour Tour @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@id([userId, tourId])
  @@index([tourId])
  @@map("wishlist")
}

// ─────────────────────────────────────────────────────────────────────────────
// PaymentEvent — webhook idempotency log, per provider (ADR-0006)
// ─────────────────────────────────────────────────────────────────────────────

model PaymentEvent {
  id          String          @id @default(uuid()) @db.Uuid
  provider    PaymentProvider
  eventId     String          @map("event_id") @db.VarChar(255)
  type        String          @db.VarChar(100)
  payload     Json
  // NULL = received but processing not finished → a provider retry must RE-RUN
  // the handler (handlers are idempotent at booking level).
  processedAt DateTime?       @map("processed_at")
  receivedAt  DateTime        @default(now()) @map("received_at")

  @@unique([provider, eventId])
  @@index([type])
  @@map("payment_events")
}

// ─────────────────────────────────────────────────────────────────────────────
// Enquiry — "Inquire Now" lead (ADR-0003)
// ─────────────────────────────────────────────────────────────────────────────

model Enquiry {
  id          String        @id @default(uuid()) @db.Uuid
  name        String        @db.VarChar(120)
  email       String        @db.VarChar(200)
  phone       String?       @db.VarChar(30)
  message     String        @db.VarChar(2000)
  tourId      String?       @map("tour_id") @db.Uuid
  // Structured lead fields (P1.7d) — match the donor/Lily's inbound form so sales
  // can qualify foreign travellers up front. All optional (a general enquiry omits
  // them); EN-only (ADR-0005). `interests` is a free multi-select.
  nationality String?       @db.VarChar(80)
  travelDate  DateTime?     @map("travel_date") @db.Date
  groupSize   Int?          @map("group_size")
  budgetTier  String?       @map("budget_tier") @db.VarChar(40)
  interests   String[]      @default([])
  status      EnquiryStatus @default(NEW)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  tour  Tour?         @relation(fields: [tourId], references: [id], onDelete: SetNull)
  notes EnquiryNote[]

  @@index([status, createdAt])
  @@index([tourId])
  @@index([email])
  @@map("enquiries")
}

/// Internal CRM note on an enquiry (admin-only, append-only thread). `authorName`
/// is a snapshot so the thread stays readable if the admin account is deleted
/// (`authorId` then goes null via SetNull).
model EnquiryNote {
  id         String   @id @default(uuid()) @db.Uuid
  enquiryId  String   @map("enquiry_id") @db.Uuid
  authorId   String?  @map("author_id") @db.Uuid
  authorName String   @map("author_name") @db.VarChar(200)
  body       String   @db.VarChar(2000)
  createdAt  DateTime @default(now()) @map("created_at")

  enquiry Enquiry @relation(fields: [enquiryId], references: [id], onDelete: Cascade)
  author  User?   @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([enquiryId, createdAt])
  @@map("enquiry_notes")
}

// ─────────────────────────────────────────────────────────────────────────────
// Subscriber — newsletter lead capture (blog v2 wave 5). DB-backed only (no
// ESP); the public subscribe endpoint upserts by normalized email (silent
// dedupe), admin lists/exports. RLS-enabled like every table (API enforces).
// ─────────────────────────────────────────────────────────────────────────────

model Subscriber {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique @db.VarChar(200)
  source       String?  @db.VarChar(40)
  subscribedAt DateTime @default(now()) @map("subscribed_at")

  @@map("subscribers")
}

// ─────────────────────────────────────────────────────────────────────────────
// MediaAsset — Cloudinary-backed, polymorphic by (ownerType, ownerId).
// No hard FK (ADR-0008 pragmatic) — integrity via a reconcile job + same-tx
// cleanup. Stores Cloudinary public_id; delivery URLs derived at read time.
// ─────────────────────────────────────────────────────────────────────────────

model MediaAsset {
  id          String         @id @default(uuid()) @db.Uuid
  publicId    String         @map("public_id") @db.VarChar(300)
  type        MediaType
  ownerType   MediaOwnerType @map("owner_type")
  ownerId     String         @map("owner_id") @db.Uuid
  role        MediaRole
  format      String?        @db.VarChar(10)
  width       Int?
  height      Int?
  durationSec Float?         @map("duration_sec")
  posterId    String?        @map("poster_id") @db.VarChar(300)
  bytes       Int?
  sortOrder   Int            @default(0) @map("sort_order")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  // One row per owner+publicId — lets registerAsset upsert instead of racing
  // findFirst-then-create (W3 fast-follow). Replace-all paths delete before
  // insert inside one tx, so they never collide with this.
  @@unique([ownerType, ownerId, publicId])
  @@index([ownerType, ownerId, role])
  @@map("media_assets")
}

// ─────────────────────────────────────────────────────────────────────────────
// SiteMediaSlot — one row per brand-chrome image slot on the public web (home
// hero, About story gallery, …). The catalog of keys/kinds lives in API code
// (site-media/slot-catalog.ts); this table only gives each slot a stable uuid so
// its images live in media_assets (ownerType=SITE, ownerId=slot.id) — visible to
// the admin Media Library and protected by the Cloudinary GC like every asset.
// Rows are seeded by migration; slots with no assets fall back to the web's
// built-in defaults. See docs/06-specs/2026-07-10-site-media-appearance-design.md.
// ─────────────────────────────────────────────────────────────────────────────

model SiteMediaSlot {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique @db.VarChar(60)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_media_slots")
}

// ─────────────────────────────────────────────────────────────────────────────
// Post — editorial blog article (agency-authored, P-Content). Cover/inline media
// via MediaAsset(ownerType=POST, role=hero/gallery). RLS-enabled like every table;
// access is enforced in the API (public reads PUBLISHED, admin writes). Content is
// markdown, rendered sanitized client-side. See
// docs/06-specs/2026-06-21-blog-editorial-post-schema.md.
// ─────────────────────────────────────────────────────────────────────────────

model Post {
  id          String     @id @default(uuid()) @db.Uuid
  slug        String     @unique @db.VarChar(80)
  title       String     @db.VarChar(160)
  excerpt     String?    @db.VarChar(300)
  content     String
  // SEO overrides for the web reader's <title>/meta description (fall back to
  // title/excerpt when null). Length caps match SERP display limits.
  metaTitle       String? @map("meta_title") @db.VarChar(70)
  metaDescription String? @map("meta_description") @db.VarChar(160)
  status      PostStatus @default(DRAFT)
  publishedAt DateTime?  @map("published_at")
  authorId    String     @map("author_id") @db.Uuid
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  author User @relation(fields: [authorId], references: [id], onDelete: Restrict)
  tags         PostTagLink[]
  relatedTours PostTour[]

  @@index([status, publishedAt])
  @@index([authorId])
  @@map("posts")
}

// ─────────────────────────────────────────────────────────────────────────────
// PostTag — free-form blog taxonomy (created inline from the admin post form).
// Slug is the identity (upsert target); display name = first writer's casing.
// ─────────────────────────────────────────────────────────────────────────────

model PostTag {
  id        String   @id @default(uuid()) @db.Uuid
  slug      String   @unique @db.VarChar(60)
  name      String   @db.VarChar(60)
  createdAt DateTime @default(now()) @map("created_at")

  posts PostTagLink[]

  @@map("post_tags")
}

model PostTagLink {
  postId String @map("post_id") @db.Uuid
  tagId  String @map("tag_id") @db.Uuid

  post Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  PostTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId])
  @@map("post_tag_links")
}

// ─────────────────────────────────────────────────────────────────────────────
// PostTour — admin-curated "tours in this story" (max 3 enforced at the DTO).
// `order` = pick order. Tour deletion silently drops the link (post survives).
// ─────────────────────────────────────────────────────────────────────────────

model PostTour {
  postId String @map("post_id") @db.Uuid
  tourId String @map("tour_id") @db.Uuid
  order  Int    @default(0)

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tour Tour @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@id([postId, tourId])
  @@index([tourId])
  @@map("post_tours")
}

// ─────────────────────────────────────────────────────────────────────────────
// Outbox — transactional email outbox (ADR-0007, P1.x).
//
// A row is written ATOMICALLY with the state change it announces: the PAID
// confirmation is inserted inside `claimSeatsForPaid`'s seat-claim CTE (one
// statement, pooler-safe); review-approved / enquiry-received are inserted in a
// short `$transaction` with their own write. A pg-boss worker then drains
// PENDING rows oldest-first and dispatches via Resend. `dedupeKey` makes the
// whole pipeline idempotent under webhook/handler retries (`ON CONFLICT DO
// NOTHING`). `id` is DB-generated (`gen_random_uuid()`) so the raw-SQL CTE
// insert needs no client-side id.
// ─────────────────────────────────────────────────────────────────────────────

model Outbox {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type        EmailType
  payload     Json
  status      OutboxStatus @default(PENDING)
  attempts    Int          @default(0)
  dedupeKey   String       @unique @map("dedupe_key") @db.VarChar(200)
  lastError   String?      @map("last_error") @db.VarChar(1000)
  createdAt   DateTime     @default(now()) @map("created_at")
  processedAt DateTime?    @map("processed_at")

  @@index([status, createdAt])
  @@map("outbox")
}

// ─────────────────────────────────────────────────────────────────────────────
// MediaGarbage — orphaned Cloudinary assets awaiting destruction (ADR-0007, P1.x-b).
//
// When `MediaService` drops a `MediaAsset` row that is NOT recreated (a replaced
// avatar, a removed gallery image, a deleted owner), the asset's `publicId`
// (and video `posterId`) is recorded here in the same tx. A pg-boss cron calls
// Cloudinary `destroy` and deletes the row on success (destroy is idempotent, so
// a retry is safe); a failure bumps `attempts`/`lastError` for the next pass.
// `publicId` is UNIQUE so duplicate pending entries collapse.
// ─────────────────────────────────────────────────────────────────────────────

model MediaGarbage {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  publicId     String   @unique @map("public_id") @db.VarChar(300)
  // Cloudinary resource_type ('image' | 'video') — destroy needs it to find the asset.
  resourceType String   @default("image") @map("resource_type") @db.VarChar(10)
  attempts     Int      @default(0)
  lastError    String?  @map("last_error") @db.VarChar(1000)
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("media_garbage")
}
