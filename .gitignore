# Tourism Platform — Nx monorepo (api · web · admin · mobile)
# https://docs.github.com/en/get-started/git-basics/ignoring-files

# ── Build & cache ─────────────────────────────────────────────────────────────
dist/
tmp/
out-tsc/
test-output/
*.tsbuildinfo
.nx/cache
.nx/workspace-data
.nx/polygraph
.nx/self-healing

# Next.js
.next/
out/

# Expo / React Native (see also apps/mobile/.gitignore)
.expo/
web-build/
dist-test-export/
.metro-health-check*
cache/

# Expo prebuild — regenerate locally; do not commit generated native trees
apps/mobile/android/
apps/mobile/ios/

# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
.yarn/

# ── Environment & secrets ────────────────────────────────────────────────────
.env
.env.*
!.env.example

# Signing / credentials (Expo EAS, Apple, Android)
*.jks
*.p8
*.p12
*.key
*.pem
*.mobileprovision
*.orig.*

# ── Test & coverage ────────────────────────────────────────────────────────────
coverage/
testem.log
/playwright-report/
/blob-report/
/playwright/.cache/

# ── Logs & debug ─────────────────────────────────────────────────────────────
*.log
npm-debug.*
yarn-debug.*
yarn-error.*
/libpeerconnection.log

# ── IDEs & editors ───────────────────────────────────────────────────────────
/.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
*.swp
*.swo
*~

# VS Code — keep shared workspace settings
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Cursor / Claude (local agent state — not the contract)
.cursor/
.claude/worktrees/
.claude/settings.local.json
.github/instructions/nx.instructions.md
.agents/skills/
.claude/skills/

# Session handoff scratch (see CLAUDE.md)
.remember/

# ── OS junk ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Misc tooling ─────────────────────────────────────────────────────────────
/.sass-cache
/connect.lock
/typings
.playwright-mcp/

# Ephemeral Cursor workspace uploads (not apps/*/assets app bundles)
/assets/

# Local design references — heavy wireframes; share via Drive, not git
docs/Lily Wireframes/

# Deploy previews (generated by hosting CLIs)
.vercel/
.netlify/
