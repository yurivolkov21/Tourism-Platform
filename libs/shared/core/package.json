{
  "name": "@tourism/core",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@tourism/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "nx": {
    "tags": [
      "scope:shared",
      "type:data-access"
    ],
    "targets": {
      "api-types": {
        "executor": "nx:run-commands",
        "options": {
          "command": "pnpm exec openapi-typescript http://localhost:3000/api/docs-json -o libs/shared/core/src/lib/api/schema.ts"
        }
      }
    }
  },
  "dependencies": {
    "openapi-fetch": "^0.17.0",
    "tslib": "^2.3.0"
  }
}
