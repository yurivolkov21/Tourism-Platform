{
  "name": "@tourism/tokens",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    "./tokens.css": "./generated/tokens.css",
    "./theme": "./generated/theme.js",
    ".": {
      "@tourism/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "nx": {
    "tags": [
      "scope:shared",
      "type:ui"
    ],
    "targets": {
      "tokens": {
        "command": "node libs/shared/tokens/style-dictionary/build.mjs",
        "outputs": ["{projectRoot}/generated"],
        "cache": true
      }
    }
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "style-dictionary": "^5.4.4"
  }
}
